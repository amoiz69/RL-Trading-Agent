# -----------------------------------------------------------------------
# Alpaca Paper Trading credentials
# -----------------------------------------------------------------------
# 1. Go to https://app.alpaca.markets and create a free account
# 2. Click "Paper Trading" in the left sidebar
# 3. Generate a new API key pair under "Your API Keys"
# 4. Paste them below, then rename this file to .env
#
# NEVER commit .env to git — it is already in .gitignore

ALPACA_API_KEY=your_paper_api_key_here
ALPACA_SECRET_KEY=your_paper_secret_key_here

# The ticker to trade (must be in both Alpaca and yfinance)
TRADE_TICKER=AAPL

# Which model to use: "ppo_aapl" or "ppo_multi"
MODEL_NAME=ppo_multi

# Starting cash assumption for P&L tracking (must match Alpaca paper balance)
INITIAL_CASH=100000
